# Airtable MCP Server Configuration
# Get your personal access token from https://airtable.com/account
# Required scopes: data.records:read, data.records:write, schema.bases:read, schema.bases:write
AIRTABLE_ACCESS_TOKEN=your_personal_access_token_here

# Transport (optional — default: stdio)
# MCP_TRANSPORT=http
# MCP_HTTP_PORT=3000
